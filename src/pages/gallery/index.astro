---
import GalleryIndexContent from "@/components/pages/gallery/GalleryIndexContent.astro";
import GalleryPagination from "@/components/pages/gallery/GalleryPagination.astro";
import { galleryConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedAlbums } from "@/utils/gallery-utils";

// 检查页面是否启用
if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.gallery);
const description = i18n(I18nKey.galleryDescription);

const paginationConfig = galleryConfig.pagination || {};
const enablePagination = paginationConfig.enabled ?? false;
const albumsPerPage = Math.max(1, paginationConfig.albumsPerPage || 12);

// 构建相册数据（扫描照片、获取封面）
const allAlbums = getSortedAlbums(galleryConfig.albums);

const totalPages = Math.max(1, Math.ceil(allAlbums.length / albumsPerPage));
const albums = enablePagination ? allAlbums.slice(0, albumsPerPage) : allAlbums;
---

<MainGridLayout title={title} description={description}>
	<GalleryIndexContent
		title={title}
		description={description}
		albums={albums}
		returnTo="/gallery/"
	/>
	{enablePagination && totalPages > 1 && (
		<GalleryPagination currentPage={1} totalPages={totalPages} />
	)}
</MainGridLayout>

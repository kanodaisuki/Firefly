---
import { getImage } from "astro:assets";
import { Icon } from "astro-icon/components";
import Comment from "@components/comment/index.astro";
import EncryptedContent from "@/components/features/EncryptedContent.astro";
import PhotoCard from "@/components/pages/gallery/PhotoCard.astro";
import { galleryConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import {
	getAlbumCover,
	getSortedAlbums,
	scanAlbumPhotos,
} from "@/utils/gallery-utils";
import { getRemoteImageWidths, shouldUseImageKitForUrl } from "@/utils/image-utils";
import { getLqipProps } from "@/utils/lqip-utils";
import { url } from "@/utils/url-utils";

// 检查页面是否启用
if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}

export function getStaticPaths() {
	return galleryConfig.albums.map((album) => ({
		params: { album: album.id },
	}));
}

const { album: albumId } = Astro.params;
const albumMeta = galleryConfig.albums.find((a) => a.id === albumId);

if (!albumMeta) {
	return Astro.redirect("/404/");
}

const photos = scanAlbumPhotos(albumMeta.id);
const cover = getAlbumCover(albumMeta, photos);
const columnWidth = galleryConfig.columnWidth || 240;
const defaultBackToGallery = url("/gallery/");

// 获取排序后的相册列表用于 prev/next 导航
const sortedAlbums = getSortedAlbums(galleryConfig.albums);
const currentAlbumIndex = sortedAlbums.findIndex((a) => a.id === albumId);
const prevAlbum = currentAlbumIndex > 0 ? sortedAlbums[currentAlbumIndex - 1] : null;
const nextAlbum = currentAlbumIndex < sortedAlbums.length - 1 ? sortedAlbums[currentAlbumIndex + 1] : null;

// LQIP 渐变占位
const coverLqipProps = cover
	? getLqipProps(cover, undefined, true)
	: { style: "" };
const allWidths = getRemoteImageWidths();
const optimizedCover =
	cover && shouldUseImageKitForUrl(cover)
		? await getImage({ src: cover, inferSize: true, widths: allWidths })
		: null;
const sizes = "(max-width: 768px) 100vw, (max-width: 1600px) 80vw, 1300px";
---

<MainGridLayout title={albumMeta.name} description={albumMeta.description || ""}>
  <!-- 相册封面横幅 -->
  <div class="w-full rounded-(--radius-large) overflow-hidden relative">
    {cover ? (
      <div class="relative w-full aspect-[3/1] min-h-[200px] max-h-[360px] overflow-hidden">
        <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={coverLqipProps.style} aria-hidden="true"></div>
        <img
          src={optimizedCover?.src || cover}
          srcset={optimizedCover?.srcSet.attribute}
          alt={albumMeta.name}
          class="w-full h-full object-cover opacity-0 transition-opacity duration-500 ease-out"
          sizes={sizes}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
        <!-- 返回按钮 -->
        <a
          href={defaultBackToGallery}
          data-gallery-back-link
          class="absolute top-4 left-4 inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-black/30 hover:bg-black/50 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors"
        >
          <Icon is:inline name="material-symbols:arrow-back" class="text-base" />
          {i18n(I18nKey.galleryBackToAlbums)}
        </a>
        <!-- 封面上的信息 -->
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-2 drop-shadow-lg">
            {albumMeta.name}
          </div>
          {albumMeta.description && (
            <p class="text-sm text-white/75 leading-relaxed mb-2 max-w-2xl line-clamp-2">
              {albumMeta.description}
            </p>
          )}
          <div class="flex items-center gap-4 text-sm text-white/80 flex-wrap">
            {albumMeta.date && (
              <span class="inline-flex items-center gap-1">
                <Icon is:inline name="material-symbols:calendar-today" class="text-sm" />
                {albumMeta.date}
              </span>
            )}
            {albumMeta.location && (
              <span class="inline-flex items-center gap-1">
                <Icon is:inline name="material-symbols:location-on" class="text-sm" />
                {albumMeta.location}
              </span>
            )}
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:photo-library" class="text-sm" />
              {photos.length} {i18n(I18nKey.galleryPhotos)}
            </span>
          </div>
          {albumMeta.tags && albumMeta.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2.5">
              {albumMeta.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded bg-white/20 text-white/90 backdrop-blur-sm">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="card-base px-6 py-4">
        <a
          href={defaultBackToGallery}
          data-gallery-back-link
          class="inline-flex items-center gap-1 text-sm text-(--primary) hover:underline mb-3"
        >
          <Icon is:inline name="material-symbols:arrow-back" class="text-base" />
          {i18n(I18nKey.galleryBackToAlbums)}
        </a>
        <div class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-neutral-100">
          {albumMeta.name}
        </div>
        <div class="flex items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400 mt-2 flex-wrap">
          {albumMeta.date && (
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:calendar-today" class="text-sm" />
              {albumMeta.date}
            </span>
          )}
          {albumMeta.location && (
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:location-on" class="text-sm" />
              {albumMeta.location}
            </span>
          )}
          <span>{photos.length} {i18n(I18nKey.galleryPhotos)}</span>
        </div>
      </div>
    )}
  </div>

  <!-- 瀑布流照片网格 -->
  <div class="w-full rounded-(--radius-large) overflow-hidden relative mt-4">
    <div class="card-base z-10 px-6 py-6 relative w-full">
      {photos.length > 0 ? (
        albumMeta.password ? (
          <EncryptedContent password={albumMeta.password} slug={albumMeta.id} hint={albumMeta.passwordHint}>
            <div
              class="gallery-masonry"
              style={`column-count: 2; column-gap: 0.75rem; --col-width: ${columnWidth}px;`}
            >
              {photos.map((photo) => (
                <PhotoCard src={photo} albumId={albumMeta.id} />
              ))}
            </div>
          </EncryptedContent>
        ) : (
          <div
            class="gallery-masonry"
            style={`column-count: 2; column-gap: 0.75rem; --col-width: ${columnWidth}px;`}
          >
            {photos.map((photo) => (
              <PhotoCard src={photo} albumId={albumMeta.id} />
            ))}
          </div>
        )
      ) : (
        <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
          <Icon is:inline name="material-symbols:photo-library" class="text-6xl mb-4 opacity-50" />
          <p class="text-lg">{i18n(I18nKey.galleryNoAlbums)}</p>
        </div>
      )}
    </div>
  </div>

  <!-- 上一个相册 / 下一个相册 导航 -->
  <div
    class="flex flex-col md:flex-row justify-between mt-4 mb-4 gap-4 overflow-hidden w-full"
  >
    <a
      href={prevAlbum ? url(`/gallery/${prevAlbum.id}/`) : defaultBackToGallery}
      class="w-full font-bold overflow-hidden active:scale-95"
    >
      <div class="btn-card rounded-2xl w-full h-15 max-w-full px-4 flex items-center justify-start! gap-4">
        <Icon is:inline
          name="material-symbols:chevron-left-rounded"
          class="text-[2rem] text-(--primary)"
        />
        <div class="overflow-hidden transition text-ellipsis whitespace-nowrap max-w-[calc(100%-3rem)] text-black/75 dark:text-white/75">
          {prevAlbum?.name || i18n(I18nKey.gallery)}
        </div>
      </div>
    </a>

    <a
      href={nextAlbum ? url(`/gallery/${nextAlbum.id}/`) : defaultBackToGallery}
      class="w-full font-bold overflow-hidden active:scale-95"
    >
      <div class="btn-card rounded-2xl w-full h-15 max-w-full px-4 flex items-center justify-end! gap-4">
        <div class="overflow-hidden transition text-ellipsis whitespace-nowrap max-w-[calc(100%-3rem)] text-black/75 dark:text-white/75">
          {nextAlbum?.name || i18n(I18nKey.gallery)}
        </div>
        <Icon is:inline
          name="material-symbols:chevron-right-rounded"
          class="text-[2rem] text-(--primary)"
        />
      </div>
    </a>
  </div>

  <!-- 评论 -->
  {albumMeta.comment && !albumMeta.password && <Comment customPath={`/gallery/${albumMeta.id}/`} title={albumMeta.name} />}

</MainGridLayout>

<script slot="head" is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
  const isSafeGalleryPath = (path) => {
    if (!path || !path.startsWith("/") || path.startsWith("//")) return false;
    if (path === "/gallery" || path === "/gallery/") return true;
    return /^\/gallery\/\d+\/?$/.test(path);
  };

  const normalizeGalleryPath = (path) => {
    if (path === "/gallery") return "/gallery/";
    if (/^\/gallery\/\d+$/.test(path)) return `${path}/`;
    return path;
  };

  const withBase = (path) => {
    const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
    const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
    return `${normalizedBase}${normalizedPath}`;
  };

  const applyGalleryBackLink = () => {
    const from = new URL(window.location.href).searchParams.get("from")?.trim();
    if (!from || !isSafeGalleryPath(from)) return;

    const href = withBase(normalizeGalleryPath(from));
    document
      .querySelectorAll("[data-gallery-back-link]")
      .forEach((el) => el.setAttribute("href", href));
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", applyGalleryBackLink, {
      once: true,
    });
  } else {
    applyGalleryBackLink();
  }
</script>

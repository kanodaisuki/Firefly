---
import { Icon } from "astro-icon/components";
import AlbumCard from "@/components/pages/gallery/AlbumCard.astro";
import { galleryConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

type GalleryPageAlbum = {
	id: string;
	name: string;
	cover: string;
	description?: string;
	date?: string;
	location?: string;
	tags?: string[];
	password?: string;
	photoCount: number;
};

interface Props {
	title: string;
	description: string;
	albums: GalleryPageAlbum[];
}

const { title, description, albums } = Astro.props;

// 收集所有标签用于筛选
const allTags = [...new Set(albums.flatMap((a) => a.tags || []))].sort();

const indexLayout = galleryConfig.indexLayout || {};
const isFlowLayout = indexLayout.mode === "flow";
const enableSearch = indexLayout.enableSearch ?? true;
const enableTagFilter = indexLayout.enableTagFilter ?? true;
const flowMinColumnWidth = indexLayout.flowMinColumnWidth || 260;
const flowMaxColumns = Math.max(1, indexLayout.flowMaxColumns || 2);
const flowGap = indexLayout.flowGap || 16;
const adaptiveAspectRatio = indexLayout.adaptiveAspectRatio ?? true;
const showFilterControls =
	albums.length > 0 && (enableSearch || (enableTagFilter && allTags.length > 0));
---

<div
	class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
>
	<div class="card-base z-10 px-9 py-6 relative w-full">
		<!-- 页面标题和描述 -->
		<div class="mb-4">
			<div class="flex items-center gap-3 mb-3">
				<div
					class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70"
				>
					<Icon is:inline name="material-symbols:photo-library" class="text-[1.5rem]" />
				</div>
				<div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
					{title}
				</div>
			</div>
			{description && (
				<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
					{description}
				</p>
			)}
		</div>

		<!-- 搜索框 + 标签筛选 -->
		{showFilterControls && (
			<gallery-filter class="mb-6">
				{enableSearch && (
					<div class="relative mb-3">
						<Icon is:inline
							name="material-symbols:search"
							class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 dark:text-neutral-500 text-lg pointer-events-none"
						/>
						<input
							type="text"
							data-search
							placeholder={i18n(I18nKey.searchAlbums)}
							class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-(--line-divider) bg-transparent text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:border-(--primary) focus:ring-1 focus:ring-(--primary) outline-none transition-all duration-200 text-sm"
						/>
					</div>
				)}
				{enableTagFilter && allTags.length > 0 && (
					<div class="flex flex-wrap gap-2">
						<button
							data-tag="all"
							class="btn-regular px-3 py-1.5 rounded-lg bg-(--primary) text-white hover:bg-(--primary) transition-colors duration-200 text-sm font-medium"
						>
							{i18n(I18nKey.all)}
						</button>
						{allTags.map((tag) => (
							<button
								data-tag={tag}
								class="btn-regular px-3 py-1.5 rounded-lg bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover) transition-colors duration-200 text-sm font-medium"
							>
								{tag}
							</button>
						))}
					</div>
				)}
			</gallery-filter>
		)}

		<!-- 相册卡片网格 -->
		{albums.length > 0 ? (
			<>
				<div
					class:list={[
						"my-4",
						isFlowLayout
							? "gallery-flow-layout"
							: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4",
					]}
					style={
						isFlowLayout
							? `--gallery-flow-min-width: ${flowMinColumnWidth}px; --gallery-flow-max-columns: ${flowMaxColumns}; --gallery-flow-gap: ${flowGap}px;`
							: undefined
					}
				>
					{albums.map((album) => (
						<AlbumCard
							id={album.id}
							name={album.name}
							cover={album.cover}
							description={album.description}
							date={album.date}
							location={album.location}
							tags={album.tags}
							photoCount={album.photoCount}
							encrypted={!!album.password}
							adaptiveAspectRatio={isFlowLayout && adaptiveAspectRatio}
						/>
					))}
				</div>
				{/* 搜索无结果提示 */}
				<div class="albums-empty hidden flex-col items-center justify-center py-12 text-neutral-400 dark:text-neutral-500">
					<Icon is:inline name="material-symbols:search-off-rounded" class="text-4xl mb-3" />
					<div class="text-sm">{i18n(I18nKey.searchNoResults)}</div>
				</div>
			</>
		) : (
			<div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
				<Icon is:inline name="material-symbols:photo-library" class="text-6xl mb-4 opacity-50" />
				<p class="text-lg">{i18n(I18nKey.galleryNoAlbums)}</p>
			</div>
		)}
	</div>
</div>

<style is:inline>
	.gallery-flow-layout {
		column-width: var(--gallery-flow-min-width, 260px);
		column-gap: var(--gallery-flow-gap, 16px);
		max-width: calc(
			var(--gallery-flow-max-columns, 2) * var(--gallery-flow-min-width, 260px) +
				(var(--gallery-flow-max-columns, 2) - 1) * var(--gallery-flow-gap, 16px)
		);
		margin-inline: auto;
	}

	.gallery-flow-layout > .album-card {
		display: block;
		width: 100%;
		margin: 0 0 var(--gallery-flow-gap, 16px);
		break-inside: avoid;
		-webkit-column-break-inside: avoid;
		page-break-inside: avoid;
	}

	.gallery-flow-layout .album-cover[data-adaptive-ratio="true"][data-orientation="landscape"] {
		aspect-ratio: 3 / 2;
	}

	.gallery-flow-layout .album-cover[data-adaptive-ratio="true"][data-orientation="portrait"] {
		aspect-ratio: 2 / 3;
	}
</style>

<script slot="head" is:inline define:vars={{ enableSearch, enableTagFilter }}>
	const setCoverAspectByImage = (coverEl) => {
		const img = coverEl.querySelector("img");
		if (!img) return;

		const applyRatio = () => {
			if (!img.naturalWidth || !img.naturalHeight) return;

			const isPortrait = img.naturalHeight > img.naturalWidth;
			coverEl.dataset.orientation = isPortrait ? "portrait" : "landscape";
		};

		if (img.complete) {
			applyRatio();
		} else if (img.dataset.orientationBound !== "true") {
			img.addEventListener("load", applyRatio, { once: true });
			img.dataset.orientationBound = "true";
		}
	};

	const updateAlbumCoverRatios = (root = document) => {
		const covers = root.querySelectorAll(
			".album-cover[data-adaptive-ratio='true']",
		);
		covers.forEach((coverEl) => setCoverAspectByImage(coverEl));
	};

	if (!customElements.get("gallery-filter")) {
		class GalleryFilter extends HTMLElement {
			selectedTag = enableTagFilter ? "all" : "";

			constructor() {
				super();
			}

			connectedCallback() {
				this.addEventListener("click", this.handleClick);
				const input = enableSearch ? this.querySelector("[data-search]") : null;
				if (input && enableSearch) {
					input.addEventListener("input", () => this.applyFilters());
				}

				updateAlbumCoverRatios();
			}

			disconnectedCallback() {
				this.removeEventListener("click", this.handleClick);
			}

			handleClick(e) {
				if (!enableTagFilter) return;

				const target = e.target;
				const button = target.closest("button");
				if (!button) return;

				this.selectedTag = button.dataset.tag;
				const filters = this.querySelectorAll("button");

				filters.forEach((f) => {
					f.classList.remove("bg-(--primary)", "text-white");
					f.classList.remove("hover:bg-(--primary)");
					f.classList.add("bg-(--btn-regular-bg)", "text-(--btn-content)");
					f.classList.add("hover:bg-(--btn-regular-bg-hover)");

					if (f === button) {
						f.classList.remove("bg-(--btn-regular-bg)", "text-(--btn-content)");
						f.classList.remove("hover:bg-(--btn-regular-bg-hover)");
						f.classList.add("bg-(--primary)", "text-white");
						f.classList.add("hover:bg-(--primary)");
					}
				});

				this.applyFilters();
			}

			applyFilters() {
				const container = this.closest(".card-base");
				if (!container) return;

				const input = enableSearch ? this.querySelector("[data-search]") : null;
				const query = (input?.value || "").toLowerCase().trim();
				const cards = container.querySelectorAll(".album-card");

				let hasVisible = false;

				cards.forEach((card) => {
					const cardEl = card;
					const tags = (cardEl.dataset.tags || "").split(",");
					const name = (cardEl.querySelector("h3")?.textContent || "").toLowerCase();
					const desc = (cardEl.querySelector("p")?.textContent || "").toLowerCase();
					const location = (cardEl.querySelector(".inline-flex")?.textContent || "").toLowerCase();

					const tagMatch =
						!enableTagFilter ||
						this.selectedTag === "all" ||
						(this.selectedTag && tags.includes(this.selectedTag));
					const searchMatch =
						!enableSearch ||
						!query ||
						name.includes(query) ||
						desc.includes(query) ||
						location.includes(query) ||
						tags.some((t) => t.toLowerCase().includes(query));

					if (tagMatch && searchMatch) {
						cardEl.style.display = "";
						cardEl.classList.add("animate-fade-in-up");
						hasVisible = true;
					} else {
						cardEl.style.display = "none";
						cardEl.classList.remove("animate-fade-in-up");
					}
				});

				const emptyEl = container.querySelector(".albums-empty");
				if (emptyEl) {
					emptyEl.classList.toggle("hidden", hasVisible);
					emptyEl.classList.toggle("flex", !hasVisible);
				}

				updateAlbumCoverRatios(container);
			}
		}
		customElements.define("gallery-filter", GalleryFilter);
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => updateAlbumCoverRatios(), {
			once: true,
		});
	} else {
		updateAlbumCoverRatios();
	}
	document.addEventListener("astro:page-load", () => updateAlbumCoverRatios());
</script>

---
// lightGallery 灯箱组件 - 替代 Fancybox
import "lightgallery/css/lightgallery-bundle.min.css";
---

<script>
  import type { LightGallery } from "lightgallery/lightgallery";
  import type { LightGallerySettings } from "lightgallery/lg-settings";
  import type { LgQuery } from "lightgallery/lgQuery";

  /** lightGallery 插件构造函数签名 */
  interface LgPluginConstructor {
    new (instance: LightGallery, $LG: LgQuery): void;
  }

  /** 扩展 lightGallery 工厂函数，挂载插件构造函数 */
  interface LightGalleryFactory {
    (el: HTMLElement, options?: LightGallerySettings): LightGallery;
    lgZoom?: LgPluginConstructor;
    lgThumbnail?: LgPluginConstructor;
    lgRotate?: LgPluginConstructor;
    lgFullscreen?: LgPluginConstructor;
    lgAutoplay?: LgPluginConstructor;
    lgMediumZoom?: LgPluginConstructor;
  }

  let lg: LightGalleryFactory | null = null;
  const instances: LightGallery[] = [];

  // 文章图片选择器
  const POST_IMG_SELECTOR = ".custom-md";
  // 相册图片选择器
  const GALLERY_SELECTOR = ".gallery-masonry";
  // 封面 & 动态图片
  const MISC_IMG_SELECTOR = "#post-cover, .moment-images";

  /** 获取已加载的插件列表 */
  function getCommonPlugins(): LgPluginConstructor[] {
    if (!lg) return [];
    return [
      lg.lgZoom!,
      lg.lgThumbnail!,
      lg.lgRotate!,
      lg.lgFullscreen!,
      lg.lgAutoplay!,
    ];
  }

  /** 通用 lightGallery 设置 */
  function getCommonSettings(): LightGallerySettings {
    const isDark = document.documentElement.classList.contains("dark");
    return {
      speed: 500,
      download: false,
      hideScrollbar: false,
      resetScrollPosition: true,
      closable: true,
      counter: true,
      hideBarsDelay: 3000,
      showBarsAfter: 100,
      backdropDuration: 300,
      loop: true,
      slideDelay: 0,
      preload: 0,
      mousewheel: true,
      swipeThreshold: 50,
      hash: true,
      infiniteZoom: true,
      backgroundColor: isDark ? "#0d0d0d" : "#f5f5f5",
    };
  }

  /** 根据当前主题更新所有已创建灯箱实例的背景色 */
  function updateBackdropColors(): void {
    const isDark = document.documentElement.classList.contains("dark");
    const color = isDark ? "#0d0d0d" : "#f5f5f5";
    for (const inst of instances) {
      try {
        if (inst.$backdrop) {
          inst.$backdrop.css("background-color", color);
        }
      } catch {
        /* 实例可能已销毁 */
      }
    }
  }

  /** 销毁所有 lightGallery 实例 */
  function destroyAll(): void {
    for (const inst of instances) {
      try {
        inst.destroy();
      } catch {
        /* 实例可能已被销毁，忽略错误 */
      }
    }
    instances.length = 0;
  }

  /** 初始化所有 lightGallery 实例 */
  async function setup(): Promise<void> {
    destroyAll();

    if (!lg) {
      const mod: { default: LightGalleryFactory } = await import("lightgallery");
      lg = mod.default;
      // 动态导入插件
      const [zoomMod, thumbMod, rotateMod, fullscreenMod, autoplayMod, mediumZoomMod] =
        await Promise.all([
          import("lightgallery/plugins/zoom"),
          import("lightgallery/plugins/thumbnail"),
          import("lightgallery/plugins/rotate"),
          import("lightgallery/plugins/fullscreen"),
          import("lightgallery/plugins/autoplay"),
          import("lightgallery/plugins/mediumZoom"),
        ]);
      lg.lgZoom = zoomMod.default as LgPluginConstructor;
      lg.lgThumbnail = thumbMod.default as LgPluginConstructor;
      lg.lgRotate = rotateMod.default as LgPluginConstructor;
      lg.lgFullscreen = fullscreenMod.default as LgPluginConstructor;
      lg.lgAutoplay = autoplayMod.default as LgPluginConstructor;
      lg.lgMediumZoom = mediumZoomMod.default as LgPluginConstructor;
    }

    const commonPlugins = getCommonPlugins();
    const commonSettings = getCommonSettings();

    // 1. 文章内容图片 - 每个 [data-src] 元素作为一个灯箱项（与相册实现一致）
    document.querySelectorAll(POST_IMG_SELECTOR).forEach((el) => {
      const items = el.querySelectorAll("[data-src]");
      if (items.length === 0) return;

      const instance = lg!(el as HTMLElement, {
        ...commonSettings,
        plugins: commonPlugins,
        selector: "[data-src]",
        exThumbImage: "data-thumb",
      });
      instances.push(instance);
    });

    // 2. 相册页面 - 每个 .gallery-masonry 容器独立为一个画廊
    document.querySelectorAll(GALLERY_SELECTOR).forEach((el) => {
      const items = el.querySelectorAll("[data-src]");
      if (items.length === 0) return;
      const instance = lg!(el as HTMLElement, {
        ...commonSettings,
        plugins: commonPlugins,
        selector: "[data-src]",
        exThumbImage: "data-thumb",
        thumbWidth: 80,
        thumbHeight: "60px",
        animateThumb: true,
        thumbnail: true,
      });
      instances.push(instance);
    });

    // 3. 封面图 / 动态图片 - 类媒体放大，不显示缩略图
    document.querySelectorAll(MISC_IMG_SELECTOR).forEach((el) => {
      const imgs = el.querySelectorAll("img");
      if (imgs.length === 0) return;
      const miscPlugins = [
        lg!.lgZoom!,
        lg!.lgRotate!,
        lg!.lgFullscreen!,
        lg!.lgAutoplay!,
        lg!.lgMediumZoom!,
      ];
      const instance = lg!(el as HTMLElement, {
        ...commonSettings,
        plugins: miscPlugins,
        selector: "img",
        mediumZoom: true,
        margin: 80,
      });
      instances.push(instance);
    });
  }

  // 初始化
  setup();

  // Swup 生命周期整合
  document.addEventListener("swup:content:replace", setup);
  document.addEventListener("swup:visit:start", destroyAll);

  // 监听主题切换（dark 类变化），实时更新灯箱背景色
  const themeObserver = new MutationObserver(() => {
    updateBackdropColors();
  });
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"],
  });

  // 加密文章解密后重新绑定
  document.addEventListener("password:decrypted", () => {
    setTimeout(setup, 200);
  });
</script>

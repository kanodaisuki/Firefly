---
import { getImage, Image, Picture } from "astro:assets";
import * as path from "node:path";
import type { ImageMetadata } from "astro";
import type { ImageFormat, ResponsiveImageLayout } from "@/types/config";
import {
	getFallbackFormat,
	getImageFormats,
	getImageQuality,
	getRemoteImageSizes,
	getRemoteImageWidths,
	shouldAddNoReferrer,
	shouldUseImageKitForUrl,
} from "@/utils/image-utils";
import { getLqipProps } from "@/utils/lqip-utils";
import { url } from "@/utils/url-utils";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	loading?: "lazy" | "eager";
	fetchpriority?: "high" | "low" | "auto";
	// 响应式图像属性
	layout?: ResponsiveImageLayout;
	usePicture?: boolean;
	formats?: ImageFormat[];
	widths?: number[];
	sizes?: string;
	quality?: number;
}

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	loading = "lazy",
	fetchpriority = "auto",
	layout = "constrained",
	usePicture = true,
	formats = getImageFormats(),
	widths,
	sizes,
	quality = getImageQuality(),
} = Astro.props;

const fallbackFormat = getFallbackFormat();
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
let img: ImageMetadata | null = null;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,webp,avif}",
		{
			import: "default",
		},
	);
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	} else {
		img = await file();
	}
}

const imageClass =
	"w-full h-full object-cover opacity-0 transition-opacity duration-500 ease-out";
const imageStyle = `object-position: ${position}`;

// 检查是否需要添加 referrerpolicy（仅对非本地图片）
const fullSrc = isPublic ? url(src) : src;
const referrerPolicy =
	!isLocal && shouldAddNoReferrer(fullSrc) ? "no-referrer" : undefined;

const remoteSrc = isPublic ? url(src) : src;
const remoteWidths =
	widths && widths.length > 0 ? widths : getRemoteImageWidths();
const remoteSizes = sizes || getRemoteImageSizes(layout);
const remoteUseService = !isLocal && shouldUseImageKitForUrl(remoteSrc);

let remoteDefaultImage: Awaited<ReturnType<typeof getImage>> | null = null;
let remoteAvifImage: Awaited<ReturnType<typeof getImage>> | null = null;
let remoteWebpImage: Awaited<ReturnType<typeof getImage>> | null = null;

if (remoteUseService) {
	const baseRemoteOptions = {
		src: remoteSrc,
		inferSize: true,
		widths: remoteWidths,
		sizes: remoteSizes,
		quality,
	};

	remoteDefaultImage = await getImage(baseRemoteOptions);

	if (formats.includes("avif")) {
		remoteAvifImage = await getImage({
			...baseRemoteOptions,
			format: "avif",
		});
	}

	if (formats.includes("webp")) {
		remoteWebpImage = await getImage({
			...baseRemoteOptions,
			format: "webp",
		});
	}
}

// 构建响应式图像属性
const responsiveProps = {
	...(layout && { layout }),
	...(widths && { widths }),
	...(sizes && { sizes }),
	...(quality && { quality }),
};

// LQIP 渐变占位
const lqipProps = isLocal
	? getLqipProps(src, basePath)
	: isPublic
		? getLqipProps(src, basePath, true)
		: getLqipProps(src);
---
<div id={id} class:list={[className, 'overflow-hidden relative']}>
    <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={lqipProps.style} aria-hidden="true"></div>
    <div class="transition absolute inset-0 dark:bg-black/10 pointer-events-none"></div>
    {isLocal && img && usePicture && (
        <Picture
            src={img}
            alt={alt || ""}
            class={imageClass}
            style={imageStyle}
            loading={loading}
            fetchpriority={fetchpriority}
            formats={formats}
            fallbackFormat={fallbackFormat}
            {...responsiveProps}
        />
    )}
    {isLocal && img && !usePicture && (
        <Image
            src={img}
            alt={alt || ""}
            class={imageClass}
            style={imageStyle}
            loading={loading}
            fetchpriority={fetchpriority}
            {...responsiveProps}
        />
    )}
	{!isLocal && remoteUseService && usePicture && remoteDefaultImage && (
		<picture>
			{remoteAvifImage?.srcSet.attribute && (
				<source type="image/avif" srcset={remoteAvifImage.srcSet.attribute} sizes={remoteSizes} />
			)}
			{remoteWebpImage?.srcSet.attribute && (
				<source type="image/webp" srcset={remoteWebpImage.srcSet.attribute} sizes={remoteSizes} />
			)}
			<img
				src={remoteDefaultImage.src}
				srcset={remoteDefaultImage.srcSet.attribute}
				sizes={remoteSizes}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				fetchpriority={fetchpriority}
				referrerpolicy={referrerPolicy}
			/>
		</picture>
	)}
	{!isLocal && remoteUseService && !usePicture && remoteDefaultImage && (
		<img
			src={remoteDefaultImage.src}
			srcset={remoteDefaultImage.srcSet.attribute}
			sizes={remoteSizes}
			alt={alt || ""}
			class={imageClass}
			style={imageStyle}
			loading={loading}
			fetchpriority={fetchpriority}
			referrerpolicy={referrerPolicy}
		/>
	)}
	{!isLocal && !remoteUseService && (
		<img
			src={remoteSrc}
			alt={alt || ""}
			class={imageClass}
			style={imageStyle}
			loading={loading}
			fetchpriority={fetchpriority}
			referrerpolicy={referrerPolicy}
		/>
	)}
</div>
